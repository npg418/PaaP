{
  "manifest_version": 3,
  "name": "PDF as a Page for Manaba",
  "short_name": "PaaP for Manaba",
  "version": "0.1.3",
  "description": "__MSG_extensionDescription__",
  "default_locale": "ja",
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "permissions": [
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "*://manaba.tsukuba.ac.jp/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "paap.itf@npg418.com",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}
